#!/usr/bin/env sh
set -eu

duration=10
interval=0.1
steps=100
width=28

hide_cursor() {
  printf '\033[?25l'
}

show_cursor() {
  printf '\033[?25h'
}

cleanup() {
  show_cursor
}

trap cleanup EXIT INT TERM

repeat_char() {
  char=$1
  count=$2
  output=

  while [ "$count" -gt 0 ]; do
    output="${output}${char}"
    count=$((count - 1))
  done

  printf '%s' "$output"
}

hide_cursor
printf 'Compact loader demo: 10 ASCII variants, %s seconds\n\n' "$duration"

line=0
while [ "$line" -lt 10 ]; do
  printf '\n'
  line=$((line + 1))
done

step=0
while [ "$step" -le "$steps" ]; do
  percent=$((step * 100 / steps))
  filled=$((step * width / steps))
  empty=$((width - filled))
  printf '\033[10A'

  index=1
  while [ "$index" -le 10 ]; do
    case "$index" in
      1) symbol='#' ;;
      2) symbol='=' ;;
      3) symbol='*' ;;
      4) symbol='+' ;;
      5) symbol='-' ;;
      6) symbol='.' ;;
      7) symbol=':' ;;
      8) symbol='|' ;;
      9) symbol='/' ;;
      *) symbol='@' ;;
    esac

    filled_text=$(repeat_char "$symbol" "$filled")
    empty_text=$(repeat_char ' ' "$empty")

    printf '\r%02d %-2s %-28s %3d%%\n' "$index" "$symbol" "${filled_text}${empty_text}" "$percent"

    index=$((index + 1))
  done

  step=$((step + 1))
  sleep "$interval"
done

printf '\nDone.\n'
